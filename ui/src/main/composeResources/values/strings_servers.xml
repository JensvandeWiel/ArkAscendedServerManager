    <string name="server_details_cluster_id_label">Cluster ID</string>
    <string name="server_details_cluster_id_hint">Cluster ID is automatically set based on the selected cluster. (This field is used by ark to group servers together)</string>
    <string name="server_details_cluster_dir_override_label">Cluster Directory Override</string>
    <string name="server_details_cluster_dir_override_hint">The location where cluster data like player and item uploads are stored (This field is used by ark to group servers together)</string>
