    <string name="server_details_group_server">Server</string>
    <string name="server_details_profile_name_label">Profile name:</string>
    <string name="server_details_installation_path_label">Installation path:</string>
    <string name="server_details_installation_path_hint">Path to the server installation folder, changing this will not move the existing installation.</string>
    <string name="server_details_asa_api_label">Enable ASA API</string>
    <string name="server_details_asa_api_hint">Enables Ark Ascended Server API, which allows the use of plugins. These are not the same as mods. Requires reinstall.</string>
    <string name="server_details_cluster_label">Cluster:</string>
    <string name="server_details_server_name_label">Server name:</string>
    <string name="server_details_server_name_hint">Public name of the server</string>
    <string name="server_details_group_name_and_passwords">Name and passwords</string>
    <string name="server_details_server_password_label">Server password:</string>
    <string name="server_details_server_password_hint">The password users must enter in order to access the server. If this is set, only people who know the password can access your server.</string>
    <string name="server_details_admin_password_label">Admin password:</string>
    <string name="server_details_admin_password_hint">The password users must enter to execute admin/cheat commands on the server. If this is not set, anyone can use cheats.</string>
    <string name="server_details_group_ports">Ports</string>
    <string name="server_details_server_port_label">Server port:</string>
    <string name="server_details_server_port_hint">The port users will use to connect to your server. Default is 7777. Change this and Query Port if you wish to host multiple servers on one machine.</string>
    <string name="server_details_peer_port_label">Peer port:</string>
    <string name="server_details_peer_port_hint">Peer port (always Game port +1), used for connecting to the server from the client.</string>
    <string name="server_details_query_port_label">Query port:</string>
    <string name="server_details_query_port_hint">The port Steam uses to communicate with your server. Default is 27015. Change this and Server Port if you wish to host multiple servers on one machine.</string>
    <string name="server_details_rcon_label">RCON</string>
    <string name="server_details_rcon_hint">Enable RCON (Remote Console) for this server. This allows you to execute admin/cheat commands on the server.</string>
    <string name="server_details_rcon_port_label">RCON port:</string>
    <string name="server_details_rcon_port_hint">The port that RCON will use on your server.</string>
    <string name="server_details_group_map_and_mods">Map and Mods</string>
    <string name="server_details_map_label">Map:</string>
    <string name="server_details_map_hint">The map your server will load. Make sure to use the correct map name, otherwise your server might not start.</string>
    <string name="server_details_mods_label">Mods (comma separated):</string>
    <string name="server_details_mods_hint">A comma-separated list of mod ids, in the order in which they should be applied.</string>
    <string name="server_details_group_saves">Saves</string>
    <string name="server_details_auto_save_period_label">Auto save period (minutes)</string>
    <string name="server_details_auto_save_period_hint">Set how often the server will automatically save the game. Setting it to a very low value may impact performance, setting this to 0 will cause constant saving.</string>
    <string name="server_details_group_motd">Message of the Day</string>
    <string name="server_details_motd_message_label">Message</string>
    <string name="server_details_motd_message_hint">This message will be shown to players as a welcome message when they join the server.</string>
    <string name="server_details_motd_duration_label">Duration (seconds)</string>
    <string name="server_details_motd_duration_hint">Set how long the Message of the Day will be shown to players.</string>
    <string name="server_details_group_tribute_download_options">Tribute Download Options</string>
    <string name="server_details_enable_tribute_downloads_label">Enable Tribute Downloads</string>
    <string name="server_details_enable_tribute_downloads_hint">If enabled, this will allow downloading external survivors, items, and dinos into your server.</string>
    <string name="server_details_no_survivor_downloads_label">No Survivor Downloads</string>
    <string name="server_details_no_survivor_downloads_hint">If enabled, this will prevent downloading survivors from the server.</string>
    <string name="server_details_no_item_downloads_label">No Item Downloads</string>
    <string name="server_details_no_item_downloads_hint">If enabled, this will prevent downloading items from the server.</string>
    <string name="server_details_no_dinosaur_downloads_label">No Dinosaur Downloads</string>
    <string name="server_details_no_dinosaur_downloads_hint">If enabled, this will prevent downloading dinosaurs from the server.</string>
    <string name="server_details_foreign_dino_downloads_label">Foreign Dino Downloads</string>
    <string name="server_details_foreign_dino_downloads_hint">If enabled, this allows non-native creatures tribute downloads on Aberration.</string>
    <string name="server_details_group_tribute_upload_options">Tribute Upload Options</string>
    <string name="server_details_no_survivor_uploads_label">No Survivor Uploads</string>
    <string name="server_details_no_survivor_uploads_hint">If enabled, this will prevent uploading survivors.</string>
    <string name="server_details_no_item_uploads_label">No Item Uploads</string>
    <string name="server_details_no_item_uploads_hint">If enabled, this will prevent uploading items.</string>
    <string name="server_details_no_dinosaur_uploads_label">No Dinosaur Uploads</string>
    <string name="server_details_no_dinosaur_uploads_hint">If enabled, this will prevent uploading dinosaurs.</string>
    <string name="server_details_group_cluster_tribute_options">Cluster Tribute Options</string>
    <string name="server_details_no_transfer_from_filtering_label">No Transfer From Filtering</string>
    <string name="server_details_no_transfer_from_filtering_hint">Prevents ARK Data usage between single player and servers that do not have a cluster ID. Even with a cluster ID set, keep this enabled to fully disable code paths that allow it.</string>
    <string name="server_details_max_tribute_dino_uploads_label">Max Tribute Dino Uploads</string>
    <string name="server_details_max_tribute_dino_uploads_hint">Limits number of dinosaurs that can be uploaded in a tribute. Default is 20. Range is 20-100.</string>
    <string name="server_details_max_tribute_item_uploads_label">Max Tribute Item Uploads</string>
    <string name="server_details_max_tribute_item_uploads_hint">Limits number of items that can be uploaded in a tribute. Default is 50. Range is 50-100.</string>
    <string name="server_details_override_survivor_upload_expiration_label">Override Survivor Upload Expiration (minutes)</string>
    <string name="server_details_override_survivor_upload_expiration_hint">Enable to write tribute character expiration in minutes. Warning: do not set this option to an extremely high value; it can overflow and may cause upload time checks to fail and ARK Data to be deleted.</string>
    <string name="server_details_override_dino_upload_expiration_label">Override Dino Upload Expiration (minutes)</string>
    <string name="server_details_override_dino_upload_expiration_hint">Set, in minutes, the expiration timer for uploaded dinosaurs in ARK Data. If set to 0 or lower, the server will revert to default. Warning: do not set this option to an extremely high value; it can overflow and may cause upload time checks to fail and ARK Data to be deleted.</string>
    <string name="server_details_override_item_upload_expiration_label">Override Item Upload Expiration (minutes)</string>
    <string name="server_details_override_item_upload_expiration_hint">Set, in minutes, the expiration timer for uploaded items in ARK Data. If set to 0 or lower, the server will revert to default. Warning: do not set this option to an extremely high value; it can overflow and may cause upload time checks to fail and ARK Data to be deleted.</string>
    <string name="server_details_group_server_options">Server options</string>
    <string name="server_details_slots_label">Slots:</string>
    <string name="server_details_slots_hint">Sets the maximum number of players which can join this server.</string>
    <string name="server_details_rcon_server_game_log_buffer_label">RCON Server Game Log Buffer</string>
    <string name="server_details_rcon_server_game_log_buffer_hint">Determines how many lines of game logs are send over the RCON.</string>
    <string name="server_details_idle_player_kick_enabled_label">Enable idle player kick</string>
    <string name="server_details_idle_player_kick_enabled_hint">If enabled, idle players will be kicked from the server after a specified amount of time.</string>
    <string name="server_details_idle_player_kick_time_label">Idle player kick time (seconds):</string>
    <string name="server_details_idle_player_kick_time_hint">The amount of time (in seconds) after which idle players will be kicked from the server. This option is only relevant if idle player kick is enabled. (3600 seconds is one hour)</string>
    <string name="server_details_ban_list_url_label">Ban list URL</string>
    <string name="server_details_ban_list_url_hint">Ban list URL, sets the global ban list.</string>
    <string name="server_details_use_dynamic_config_label">Use dynamic config</string>
    <string name="server_details_use_dynamic_config_hint">Enables the use of the dynamic config</string>
    <string name="server_details_custom_dynamic_config_url_hint">URL for the dynamic config.</string>
    <string name="server_details_custom_live_tuning_url_label">Custom Live Tuning URL</string>
    <string name="server_details_custom_live_tuning_url_hint">Direct link to the live tuning file.</string>
    <string name="server_details_go_to_server">Go to server</string>
    <string name="server_details_logs_group">Server Logs</string>

    <string name="server_import_dialog_title">Import Server</string>
    <string name="server_import_select_root_folder">Select the root folder of the server installation:</string>
    <string name="server_import_installation_path_label">Installation Path</string>
    <string name="server_import_installation_path_hint">The root folder of the server installation. You can identify the installation path by looking for the 'ShooterGame' and 'Engine' folder in the server installation directory.</string>
    <string name="server_import_invalid_installation_path">The selected path is not a valid server installation.</string>

